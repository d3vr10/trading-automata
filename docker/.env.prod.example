# ============================================================================
# PRODUCTION ENVIRONMENT - Trading Bot Configuration
# ============================================================================

# ============================================================================
# BROKER CREDENTIALS (Production)
# ============================================================================

# ALPACA (Stocks, Options, Crypto, Forex - LIVE TRADING)
ALPACA_API_KEY=your_live_alpaca_api_key_here
ALPACA_SECRET_KEY=your_live_alpaca_secret_key_here

# COINBASE (Crypto only - LIVE TRADING)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET_KEY=your_coinbase_secret_key_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# ============================================================================
# BROKER SELECTION & ENVIRONMENT
# ============================================================================

# Broker: alpaca or coinbase
BROKER=alpaca

# Trading Environment: LIVE ONLY (no paper trading in production)
TRADING_ENV=live

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/trading_bot.log

# ============================================================================
# STRATEGY CONFIGURATION
# ============================================================================

STRATEGY_CONFIG_PATH=config/strategies.yaml

# ============================================================================
# RISK MANAGEMENT
# ============================================================================

# Maximum position size as percentage of portfolio (0.0 - 1.0)
MAX_POSITION_SIZE=0.1

# Maximum portfolio risk as percentage (0.0 - 1.0)
MAX_PORTFOLIO_RISK=0.02

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string - use 'postgres' service name for Docker
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trading_bot

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=trading_bot

# ============================================================================
# HEALTH CHECK CONFIGURATION
# ============================================================================

# Interval (in seconds) for saving health checks to database
HEALTH_CHECK_INTERVAL=300

# ============================================================================
# STRATEGY WARM-UP CONFIGURATION
# ============================================================================

# Use cached historical data for deterministic testing
USE_CACHED_DATA=false

# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================

# Get from BotFather: @BotFather -> /newbot
TELEGRAM_TOKEN=your_bot_token_here

# Your private Telegram channel chat ID for notifications
# Use API method to get: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=-100your_channel_id_here

# Telegram usernames allowed to use bot commands (comma-separated, with @ prefix)
TELEGRAM_USERNAME_WHITELIST=@username1,@username2

# ============================================================================
# TELEGRAM WEBHOOK CONFIGURATION (Production only)
# ============================================================================

# Public HTTPS URL where Telegram sends updates
TELEGRAM_WEBHOOK_URL=https://hermes-bot.dynv6.net

# Secret token for validating Telegram requests (generate random 32-char string)
# Use: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here_32_chars_min

# Port the bot listens on internally (Nginx reverse proxies this)
TELEGRAM_WEBHOOK_PORT=8080
