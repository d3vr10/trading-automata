# Trading Bot Docker Environment Configuration
# Copy this file to .env and fill in your values
# Environment variables have precedence over config.yml parameters

# ============================================================================
# BROKER CREDENTIALS
# ============================================================================

# ALPACA (Stocks, Options, Crypto, Forex)
# Get from: https://app.alpaca.markets/
# Required if BROKER=alpaca
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# COINBASE (Crypto only)
# Get from: https://www.coinbase.com/settings/api
# Required if BROKER=coinbase
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET_KEY=your_coinbase_secret_key_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# ============================================================================
# BROKER SELECTION & ENVIRONMENT
# ============================================================================

# Broker: alpaca or coinbase
BROKER=alpaca

# Trading Environment:
# - paper: Paper trading (test with simulated money) - Alpaca only
# - live: Live trading (CAUTION: real money)
TRADING_ENV=paper

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (inside container: /app/logs/trading_bot.log)
LOG_FILE=/app/logs/trading_bot.log

# ============================================================================
# STRATEGY CONFIGURATION
# ============================================================================
# Path to strategies YAML configuration file
STRATEGY_CONFIG_PATH=config/strategies.yaml

# Path to main config file (config.yml)
# Settings in this file are overridden by environment variables
CONFIG_FILE_PATH=config/config.yml

# ============================================================================
# RISK MANAGEMENT
# ============================================================================
# Maximum position size as percentage of portfolio (0.0 - 1.0)
# Example: 0.1 = 10% of portfolio per position
MAX_POSITION_SIZE=0.1

# Maximum portfolio risk as percentage (0.0 - 1.0)
# Example: 0.02 = limit daily loss to 2% of portfolio
MAX_PORTFOLIO_RISK=0.02

# ============================================================================
# OPTIONAL: DATABASE/PERSISTENCE
# ============================================================================
# Database URL for storing trade history and metrics
# DATABASE_URL=sqlite:///trades.db
# DATABASE_URL=postgresql://user:password@postgres:5432/trading_bot

# ============================================================================
# OPTIONAL: MONITORING/ALERTING
# ============================================================================
# Enable performance monitoring
# ENABLE_MONITORING=true

# Alert on large losses
# ALERT_ON_LOSS_PERCENTAGE=5

# Email for alerts
# ALERT_EMAIL=your_email@example.com
