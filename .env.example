# ============================================================================
# Trading Automata — Environment Variables
# ============================================================================
# Copy to docker/.env for Docker Compose, or .env at project root for local dev.
# Broker credentials (Alpaca, Coinbase) are managed through the web dashboard
# (Settings > Broker Keys) and encrypted at rest — NOT stored in env vars.
# ============================================================================

# ============================================================================
# POSTGRESQL
# ============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trading-automata

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# REDIS
# ============================================================================

REDIS_URL=redis://redis:6379/0

# ============================================================================
# API SERVICE
# ============================================================================

# JWT secret key for authentication tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Fernet key for encrypting broker credentials at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# Root user credentials (created on first startup)
# If ROOT_PASSWORD is empty, a random token is generated and printed to stdout
ROOT_USERNAME=root
ROOT_PASSWORD=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# ============================================================================
# TRADING ENGINE
# ============================================================================

LOG_LEVEL=INFO

# Strategy configuration
STRATEGY_CONFIG_PATH=config/strategies.yaml
CONFIG_FILE_PATH=config/config.yml

# Risk management
MAX_POSITION_SIZE=0.1
MAX_PORTFOLIO_RISK=0.02

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=300

# ============================================================================
# MONITORING (Optional)
# ============================================================================

GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================================================
# TELEGRAM (Optional)
# ============================================================================

# TELEGRAM_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ============================================================================
# TRAEFIK (Production only — docker-compose.prod.yml)
# ============================================================================

# TRAEFIK_HOSTNAME=your_domain_here
# LETSENCRYPT_EMAIL=admin@example.com
