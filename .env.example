# ============================================================================
# BROKER CREDENTIALS
# ============================================================================

# ALPACA (Stocks, Options, Crypto, Forex)
# Get from: https://app.alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# COINBASE (Crypto only)
# Get from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_SECRET_KEY=your_coinbase_secret_key_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# ============================================================================
# BROKER SELECTION & ENVIRONMENT
# ============================================================================

# Broker: alpaca or coinbase
BROKER=alpaca

# Trading Environment: paper (test) or live (real money)
# IMPORTANT: Paper trading only works with Alpaca
# For live Coinbase trading, set BROKER=coinbase
TRADING_ENV=paper

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/trading_automata.log

# ============================================================================
# STRATEGY CONFIGURATION
# ============================================================================

STRATEGY_CONFIG_PATH=config/strategies.yaml

# ============================================================================
# RISK MANAGEMENT
# ============================================================================

# Maximum position size as percentage of portfolio (0.0 - 1.0)
MAX_POSITION_SIZE=0.1

# Maximum portfolio risk as percentage (0.0 - 1.0)
MAX_PORTFOLIO_RISK=0.02

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Default works with docker-compose (localhost:5432)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_automata

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Docker-specific: Use 'postgres' as hostname (service name in docker-compose)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trading_automata

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trading_automata

# ============================================================================
# HEALTH CHECK CONFIGURATION
# ============================================================================

# Interval (in seconds) for saving health checks to database
# Default: 300 (5 minutes) - reduce for more frequent monitoring
HEALTH_CHECK_INTERVAL=300

# ============================================================================
# STRATEGY WARM-UP CONFIGURATION
# ============================================================================

# Use cached historical data for deterministic testing (true/false)
# Default: true - loads cached Alpaca data (instant, deterministic)
# Set to false to always fetch fresh data from Alpaca API (live mode)
USE_CACHED_DATA=true

# ============================================================================
# TELEGRAM BOT CONFIGURATION (Optional)
# ============================================================================

# Get from BotFather: @BotFather -> /newbot
# Token format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Get by sending message to your bot, then:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Chat ID format: 123456789
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# REQUIRED for bot commands: Comma-separated list of Telegram usernames allowed to use bot commands
# If empty or not set, all command access will be rejected
# Bot notifications (send_message) still work without this, but users cannot run commands
# Format: username1,username2,username3
# Example: TELEGRAM_USERNAME_WHITELIST=alice,bob,charlie
TELEGRAM_USERNAME_WHITELIST=username1,username2

# ============================================================================
# TELEGRAM WEBHOOK CONFIGURATION (Optional - Production only)
# ============================================================================

# Webhook URL for production deployment with HTTPS
# Leave empty to use polling mode (development)
# Example: https://hermes-bot.dynv6.net
TELEGRAM_WEBHOOK_URL=

# Secret token for validating webhook requests from Telegram
# Generate with: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=

# Port for webhook server to listen on (default 8080)
TELEGRAM_WEBHOOK_PORT=8080

# ============================================================================
# TRAEFIK CONFIGURATION (Production only - docker-compose.prod.yml)
# ============================================================================

# Domain/hostname for HTTPS (used in docker-compose.prod.yml)
# Example: hermes-bot.dynv6.net, trading-bot.example.com
TRAEFIK_HOSTNAME=your_domain_here

# Email for Let's Encrypt certificate registration (used in docker-compose.prod.yml)
# Example: admin@example.com
LETSENCRYPT_EMAIL=admin@example.com
